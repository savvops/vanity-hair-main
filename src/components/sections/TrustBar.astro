---
import Icon from '../ui/Icon.astro';

const trustItems = [
  { icon: 'award', text: 'Google Guaranteed' },
  { icon: 'user-shield', text: 'Fully Insured' },
  { icon: 'home', text: 'Locally Owned' },
  { icon: 'redo', text: '100% Satisfaction' },
];
---

<section class="py-10 bg-white border-b border-gray-200">
  <div class="container">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {trustItems.map(item => (
        <div class="flex items-center justify-center gap-3 p-4 bg-gray-50 rounded-xl">
          <Icon name={item.icon} class="w-6 h-6 text-primary" />
          <span class="font-semibold text-gray-800 text-sm md:text-base">{item.text}</span>
        </div>
      ))}
    </div>
  </div>
</section>
