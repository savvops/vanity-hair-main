---
import { getEntry } from 'astro:content';
const footerData = await getEntry('footer', 'settings');
const { brandName, address, copyright, socialLinks, quickLinks } = footerData?.data || {
  brandName: 'VANITY HAIR & ESTHETICS',
  address: '432 Graham Ave, Winnipeg, MB R3C 0L8',
  copyright: 'All rights reserved.',
  socialLinks: [],
  quickLinks: []
};
const currentYear = new Date().getFullYear();
---

<footer class="bg-black py-12 border-t border-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center">
      <!-- Logo -->
      <div class="mb-6 md:mb-0 text-center md:text-left">
        <span class="font-serif text-lg font-bold tracking-wider text-white">
          {brandName}
        </span>
        <p class="text-gray-600 text-sm mt-2">
          {address}<br />
          © {currentYear} {brandName}. {copyright}
        </p>
      </div>

      <!-- Social Links -->
      <div class="flex space-x-6">
        {socialLinks?.map((link: any) => (
          <a 
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-500 hover:text-gold transition-colors"
            aria-label={link.label}
          >
            <i data-lucide={link.platform} class="w-6 h-6"></i>
          </a>
        ))}
      </div>
    </div>
    
    <!-- Quick Links -->
    <div class="mt-8 pt-8 border-t border-gray-900">
      <div class="flex flex-wrap justify-center gap-6 text-sm">
        {quickLinks?.map((link: any) => (
          <a href={link.href} class="text-gray-500 hover:text-gold transition-colors">{link.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
