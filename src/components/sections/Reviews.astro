---
import { getCollection } from 'astro:content';
import Icon from '../ui/Icon.astro';
import Button from '../ui/Button.astro';

const reviews = await getCollection('reviews');
const featuredReview = reviews.find(r => r.data.featured);
const regularReviews = reviews.filter(r => !r.data.featured);
---

<section id="reviews" class="py-20 md:py-24 bg-gray-50">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">Customer Reviews</span>
      <h2 class="section-title">What Our Customers Say</h2>
      <p class="section-subtitle">Real reviews from real customers on Google</p>
    </div>
    
    <!-- Rating Summary -->
    <div class="flex flex-wrap items-center justify-center gap-8 mb-12">
      <div class="text-center">
        <span class="font-display text-7xl md:text-8xl font-extrabold text-dark">4.9</span>
        <div class="flex text-warning text-xl my-2 justify-center">
          {[...Array(4)].map(() => (
            <Icon name="star" class="w-6 h-6 fill-current" />
          ))}
          <Icon name="star" class="w-6 h-6 fill-current opacity-50" />
        </div>
        <span class="text-gray-600">Based on 150+ Google Reviews</span>
      </div>
      <Button href="https://share.google/7GyIPo0RaJ4EQ3FaX" variant="outline" target="_blank" rel="noopener">
        <Icon name="award" class="w-5 h-5" />
        View All Reviews
      </Button>
    </div>
    
    <!-- Reviews Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Featured Review -->
      {featuredReview && (
        <div class="reveal opacity-0 translate-y-8 md:row-span-2 bg-white p-8 rounded-2xl shadow-lg border-2 border-primary">
          <div class="flex items-start justify-between mb-5">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-gradient-to-br from-primary to-accent rounded-full flex items-center justify-center text-white font-semibold">
                {featuredReview.data.initials}
              </div>
              <div>
                <h4 class="font-display font-semibold text-dark">{featuredReview.data.name}</h4>
                <div class="flex text-warning text-xs">
                  {[...Array(featuredReview.data.rating)].map(() => (
                    <Icon name="star" class="w-3 h-3 fill-current" />
                  ))}
                </div>
              </div>
            </div>
            <Icon name="award" class="w-6 h-6 text-primary" />
          </div>
          <p class="text-gray-700 leading-relaxed">"{featuredReview.data.text}"</p>
        </div>
      )}
      
      <!-- Regular Reviews -->
      {regularReviews.map((review, index) => (
        <div 
          class="reveal opacity-0 translate-y-8 bg-white p-6 rounded-2xl shadow-md hover:shadow-lg transition-shadow"
          style={`transition-delay: ${(index + 1) * 100}ms`}
        >
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-gradient-to-br from-primary to-accent rounded-full flex items-center justify-center text-white text-sm font-semibold">
                {review.data.initials}
              </div>
              <div>
                <h4 class="font-display font-semibold text-dark text-sm">{review.data.name}</h4>
                <div class="flex text-warning text-xs">
                  {[...Array(review.data.rating)].map(() => (
                    <Icon name="star" class="w-3 h-3 fill-current" />
                  ))}
                </div>
              </div>
            </div>
            <Icon name="award" class="w-5 h-5 text-primary" />
          </div>
          <p class="text-gray-700 text-sm leading-relaxed">"{review.data.text}"</p>
        </div>
      ))}
    </div>
  </div>
</section>
