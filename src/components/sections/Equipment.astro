---
import Icon from '../ui/Icon.astro';

const features = [
  'Reaches difficult windows up to 3 storeys',
  'Reduces ladder risk and property disturbance',
  'Eco-friendly, detergent-free pure water clean',
  'Excellent for regular maintenance programs',
  'Windows stay cleaner longer',
];

const specs = [
  { icon: 'expand', value: '30+ ft', label: 'Pole Reach' },
  { icon: 'filter', value: '4-Stage', label: 'Filtration' },
  { icon: 'tint', value: '0 PPM', label: 'Pure Water' },
];
---

<section class="py-20 md:py-24 bg-white">
  <div class="container">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image -->
      <div class="reveal opacity-0 translate-y-8 order-2 lg:order-1">
        <img 
          src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&h=500&fit=crop" 
          alt="Professional water-fed pole window cleaning system in action"
          class="w-full rounded-3xl shadow-2xl"
        />
      </div>
      
      <!-- Content -->
      <div class="order-1 lg:order-2">
        <span class="section-badge">Our Equipment</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-dark mb-6">
          Water-Fed Poles + Purified Water Tanks
        </h2>
        <p class="text-lg text-gray-600 mb-8">
          We use advanced filtration systems and extendable poles to clean windows from the ground level. Purified water dries spot-free without harsh chemicals, leaving behind a brighter, longer-lasting clean.
        </p>
        
        <ul class="space-y-4 mb-8">
          {features.map((feature, index) => (
            <li 
              class="reveal opacity-0 translate-y-8 flex items-center gap-3"
              style={`transition-delay: ${index * 100}ms`}
            >
              <div class="w-6 h-6 rounded-full bg-success/10 flex items-center justify-center flex-shrink-0">
                <Icon name="check" class="w-4 h-4 text-success" />
              </div>
              <span class="text-gray-700">{feature}</span>
            </li>
          ))}
        </ul>
        
        <!-- Specs -->
        <div class="grid grid-cols-3 gap-4">
          {specs.map((spec, index) => (
            <div 
              class="reveal opacity-0 translate-y-8 bg-gray-50 p-4 rounded-xl text-center"
              style={`transition-delay: ${(features.length + index) * 100}ms`}
            >
              <Icon name={spec.icon} class="w-6 h-6 text-primary mx-auto mb-2" />
              <span class="block font-display text-xl font-bold text-dark">{spec.value}</span>
              <span class="text-sm text-gray-600">{spec.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
