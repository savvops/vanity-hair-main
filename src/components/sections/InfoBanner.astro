---
const infoItems = [
  {
    icon: 'map-pin',
    title: 'Location',
    content: '432 Graham Ave, Winnipeg, MB',
  },
  {
    icon: 'clock',
    title: 'Hours',
    content: 'Tue - Sat: 9am - 8:30pm',
  },
  {
    icon: 'phone',
    title: 'Contact',
    content: '(204) 956-5797',
  },
];
---

<div id="info" class="bg-charcoal border-y border-gold/20 py-8 relative z-20">
  <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8 text-center divide-y md:divide-y-0 md:divide-x divide-gray-700">
    {infoItems.map((item) => (
      <div class="p-2">
        <i data-lucide={item.icon} class="w-8 h-8 text-gold mx-auto mb-3"></i>
        <h3 class="text-white font-serif text-xl mb-1">{item.title}</h3>
        <p class="text-gray-400 text-sm">{item.content}</p>
      </div>
    ))}
  </div>
</div>
