---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';

const trustItems = [
  { icon: 'shield', text: 'Licensed & Insured' },
  { icon: 'check', text: 'Satisfaction Guaranteed' },
  { icon: 'leaf', text: 'Eco-Friendly Process' },
];
---

<section class="relative pt-32 pb-24 lg:pt-40 lg:pb-32 overflow-hidden bg-gradient-to-br from-primary-light via-white to-white">
  <!-- Background Pattern -->
  <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
  
  <div class="container relative">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Content -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-full shadow-md mb-6">
          <Icon name="star" class="w-4 h-4 text-warning fill-warning" />
          <span class="text-sm font-semibold text-gray-700">5-Star Rated on Google</span>
        </div>
        
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold text-dark leading-tight mb-6">
          Crystal-Clear Windows<br />
          <span class="text-primary relative">
            Reached Safely
            <span class="absolute bottom-1 left-0 right-0 h-3 bg-accent/20 -z-10"></span>
          </span> Up to 3 Storeys
        </h1>
        
        <p class="text-lg text-gray-600 mb-8 max-w-lg mx-auto lg:mx-0">
          Professional window cleaning using purified water-fed pole systems. No ladders needed, no streaks left behind. Experience the difference of truly clean windows.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-10">
          <Button href="#contact" variant="primary" size="lg">
            <Icon name="calendar-check" class="w-5 h-5" />
            Book Your Cleaning
          </Button>
          <Button href="tel:+15551234567" variant="outline" size="lg">
            <Icon name="phone" class="w-5 h-5" />
            (555) 123-4567
          </Button>
        </div>
        
        <div class="flex flex-wrap justify-center lg:justify-start gap-6">
          {trustItems.map(item => (
            <div class="flex items-center gap-2 text-sm font-medium text-gray-700">
              <Icon name={item.icon} class="w-5 h-5 text-success" />
              {item.text}
            </div>
          ))}
        </div>
      </div>
      
      <!-- Hero Card -->
      <div class="relative">
        <div class="bg-white rounded-3xl shadow-2xl overflow-hidden animate-float">
          <img 
            src="https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=600&h=400&fit=crop" 
            alt="Professional window cleaner using water-fed pole system on residential home"
            class="w-full h-64 lg:h-72 object-cover"
          />
          <div class="p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex text-warning">
                {[...Array(5)].map(() => (
                  <Icon name="star" class="w-5 h-5 fill-current" />
                ))}
              </div>
              <span class="text-sm font-semibold text-gray-700">4.9/5 from 150+ reviews</span>
            </div>
            <p class="text-gray-700 italic mb-2">"These guys made our windows shine so bright I put on my sunglasses!"</p>
            <span class="text-sm font-semibold text-primary">— Lori Norris, Happy Customer</span>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Wave Divider -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
      <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
    </svg>
  </div>
</section>
