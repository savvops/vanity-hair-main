---
const testimonials = [
  {
    text: "Loved my experience at Vanity Hair & Esthetics! Dereje was fantastic—took time to understand my hair type and gave expert advice on styling. The salon is super clean and friendly. My new cut frames my face perfectly!",
    author: "Kibrom Berhe",
    rating: 5,
    time: "1 month ago",
  },
  {
    text: "Great barber and excellent service! Always professional, friendly, and pays attention to detail. The shop has a clean and welcoming atmosphere, making every visit a great experience. Highly recommend!",
    author: "Sunil Sapkota",
    rating: 5,
    time: "11 months ago",
  },
  {
    text: "Best barber acts like family and treats like family. Haircut was on point and very nice guy. I recommend coming here his prices are really affordable. Thanks so much!",
    author: "Gavy Gavy",
    rating: 5,
    time: "11 months ago",
  },
  {
    text: "The Barber deserves 10 stars! Very friendly and cares for his customers. Attention to details and gives amazing haircuts every time.",
    author: "Taohidul Islam Toha",
    rating: 5,
    time: "2 months ago",
  },
];
---

<section class="py-24 relative bg-fixed bg-cover bg-center min-h-[50vh] flex items-center">
  <div class="absolute inset-0 bg-rich-black/80 z-10"></div>
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/2025-12-18_03-11-39_UTC.jpg" 
      alt="Barbershop background"
      class="w-full h-full object-cover"
    />
  </div>
  
  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Google Reviews Summary Card -->
    <div class="bg-charcoal/90 backdrop-blur-sm p-8 border border-gold/30 rounded-lg mb-12 text-center max-w-2xl mx-auto">
      <div class="flex items-center justify-center space-x-2 mb-2">
        <i data-lucide="star" class="w-8 h-8 text-gold fill-current"></i>
        <span class="text-4xl font-bold text-white">4.7</span>
      </div>
      <div class="flex items-center justify-center space-x-1 mb-2">
        {Array.from({ length: 5 }).map(() => (
          <i data-lucide="star" class="w-5 h-5 text-gold fill-current"></i>
        ))}
      </div>
      <p class="text-gray-400 mb-4">Based on 53 Google Reviews</p>
      <a 
        href="https://www.google.com/search?q=Vanity+Hair+%26+Esthetics+Reviews" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center space-x-2 px-6 py-3 bg-gold text-rich-black font-bold uppercase tracking-wider hover:bg-white transition-colors"
      >
        <i data-lucide="message-square" class="w-5 h-5"></i>
        <span>Read All Google Reviews</span>
      </a>
    </div>

    <!-- Individual Reviews -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {testimonials.map((testimonial) => (
        <div class="bg-charcoal/80 backdrop-blur-sm p-6 border border-gold/20">
          <div class="flex items-center space-x-1 text-gold mb-3">
            {Array.from({ length: testimonial.rating }).map(() => (
              <i data-lucide="star" class="w-4 h-4 fill-current"></i>
            ))}
          </div>
          <p class="text-gray-300 text-sm leading-relaxed mb-4 line-clamp-6">
            "{testimonial.text}"
          </p>
          <div class="border-t border-gray-700 pt-3">
            <p class="text-white font-semibold text-sm">{testimonial.author}</p>
            <p class="text-gray-500 text-xs">{testimonial.time}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
