---
import { getCollection, getEntry } from 'astro:content';
const settings = await getEntry('servicesSettings', 'settings');
const services = await getCollection('services');
const sortedServices = services?.sort((a: any, b: any) => (a.data.order || 0) - (b.data.order || 0)) || [];
const { heading, icon, note, ctaButton } = settings?.data || {
  heading: 'Service Menu',
  icon: 'scissors',
  note: '* Complimentary beverage with every service.',
  ctaButton: 'Book an Appointment'
};
---

<section id="services" class="py-24 bg-charcoal relative scroll-mt-24">
  <div class="absolute top-0 w-full h-2 barber-pole opacity-30"></div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <i data-lucide={icon} class="w-12 h-12 text-gold mx-auto mb-4"></i>
      <h2 class="text-4xl md:text-5xl font-serif font-bold text-white mb-4">{heading}</h2>
      <div class="h-1 w-20 bg-gold mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
      {sortedServices.map((service: any) => (
        <div class="group relative bg-rich-black p-6 border border-gray-800 hover:border-gold transition-colors duration-300">
          <div class="flex justify-between items-baseline mb-2 relative z-10">
            <h3 class="text-xl font-bold text-white group-hover:text-gold transition-colors">{service.data.title}</h3>
            <span class="text-2xl font-serif text-gold">{service.data.price}</span>
          </div>
          <p class="text-gray-500 text-sm mb-2">{service.data.description}</p>
          <div class="border-b border-dashed border-gray-800 absolute bottom-6 left-6 right-6"></div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <p class="text-gray-400 italic mb-6">{note}</p>
      <a 
        href="#book" 
        class="inline-block px-8 py-3 border border-gold text-gold hover:bg-gold hover:text-rich-black transition-all duration-300 uppercase tracking-widest text-sm font-bold"
      >
        {ctaButton}
      </a>
    </div>
  </div>
</section>
