---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Booking Confirmed | Vanity Hair & Esthetics">
  <main class="min-h-screen flex items-center justify-center bg-rich-black">
    <div class="text-center px-4">
      <div class="mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24 text-gold mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-white mb-4">
        Booking has been confirmed
      </h1>
      <p class="text-gray-400 text-lg mb-8 max-w-md mx-auto">
        Thank you for booking with us. We'll see you soon!
      </p>
      <a 
        href="/" 
        class="inline-block px-8 py-4 bg-gold text-rich-black font-bold uppercase tracking-wider hover:bg-white transition-colors"
      >
        Back to Home
      </a>
    </div>
  </main>
</Layout>
