---
import siteData from '../../content/site.json';
const { about } = siteData;
---

<section id="about" class="py-24 bg-rich-black relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Image Grid -->
      <div class="relative">
        <div class="absolute -top-4 -left-4 w-24 h-24 border-t-4 border-l-4 border-gold"></div>
        <div class="absolute -bottom-4 -right-4 w-24 h-24 border-b-4 border-r-4 border-gold"></div>
        <img 
          src={about.image} 
          alt="Vanity Hair Barbershop" 
          class="relative z-10 w-full h-[500px] object-cover grayscale hover:grayscale-0 transition-all duration-700 shadow-2xl"
        />
      </div>

      <!-- Content -->
      <div>
        <h4 class="text-gold uppercase tracking-widest font-bold mb-2">{about.subtitle}</h4>
        <h2 class="text-4xl md:text-5xl font-serif font-bold text-white mb-6">
          {about.headline_part1} <span class="italic text-gray-500">{about.headline_accent}</span>
        </h2>
        
        {about.paragraphs.map((paragraph) => (
          <p class="text-gray-400 mb-6 text-lg leading-relaxed">{paragraph}</p>
        ))}
        
        <!-- Features -->
        <div class="grid grid-cols-2 gap-4 mb-8">
          {about.features.map((feature) => (
            <div class="flex items-center space-x-3">
              <i data-lucide="check-circle" class="w-5 h-5 text-gold"></i>
              <span class="text-gray-300">{feature}</span>
            </div>
          ))}
        </div>
        
        <p class="text-gold font-serif italic text-xl">{about.signature}</p>
      </div>
    </div>
  </div>
</section>
