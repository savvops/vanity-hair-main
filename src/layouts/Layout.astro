---
import { getEntry } from 'astro:content';

interface Props {
  title?: string;
  description?: string;
}

const seoData = await getEntry('seo', 'settings');
const siteSettings = await getEntry('siteSettings', 'settings');

const defaultTitle = seoData?.data?.title || 'Vanity Hair & Esthetics | Winnipeg Barber Shop';
const defaultDescription = seoData?.data?.description || 'Winnipeg\'s premier barbershop. Precision fades, classic cuts, hot towel shaves.';
const ogImage = seoData?.data?.ogImage || '/images/vanity hair exterior.webp';

const { 
  title = defaultTitle,
  description = defaultDescription
} = Astro.props;

const siteUrl = 'https://vanityhair.pages.dev';

const schema = {
  "@context": "https://schema.org",
  "@type": "HairSalon",
  "name": siteSettings?.data?.siteName || "Vanity Hair & Esthetics",
  "image": `${siteUrl}${ogImage}`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "432 Graham Ave",
    "addressLocality": "Winnipeg",
    "addressRegion": "MB",
    "postalCode": "R3C 0L8",
    "addressCountry": "CA"
  },
  "telephone": "+12049565797",
  "priceRange": "$$",
  "openingHours": [
    "Mo 09:00-20:30",
    "Tu 09:00-20:30",
    "We 09:00-20:30",
    "Th 09:00-20:30",
    "Fr 09:00-20:30",
    "Sa 09:00-20:30"
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="business.business" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    
    <!-- Canonical -->
    <link rel="canonical" href={siteUrl} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    
    <title>{title}</title>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body class="bg-rich-black text-white">
    <slot />
    <script is:inline>
      // Immediate execution - no waiting for DOMContentLoaded
      (function() {
        // Use event delegation for all anchor clicks
        document.addEventListener('click', function(e) {
          // Find closest anchor with href starting with #
          const anchor = e.target.closest('a[href^="#"]');
          if (!anchor) return;
          
          const href = anchor.getAttribute('href');
          if (href === '#' || !href) return;
          
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            const navHeight = 80;
            const targetPosition = target.offsetTop - navHeight;
            window.scrollTo({
              top: targetPosition,
              behavior: 'smooth'
            });
          }
        });

        // Handle initial hash on page load
        if (window.location.hash) {
          setTimeout(function() {
            const target = document.querySelector(window.location.hash);
            if (target) {
              const navHeight = 80;
              const targetPosition = target.offsetTop - navHeight;
              window.scrollTo({
                top: targetPosition,
                behavior: 'instant'
              });
            }
          }, 0);
        }
      })();
      
      // Initialize Lucide icons when ready
      document.addEventListener('DOMContentLoaded', function() {
        if (window.lucide) {
          window.lucide.createIcons();
        }
        
        // Show success message if form was submitted
        if (window.location.search.includes('submitted=true')) {
          var div = document.createElement('div');
          div.textContent = 'Booking has been confirmed';
          div.style.cssText = 'position:fixed;top:100px;left:50%;transform:translateX(-50%);background:#d4af37;color:#0a0a0a;padding:16px 32px;border-radius:4px;font-weight:bold;z-index:9999;';
          document.body.appendChild(div);
          setTimeout(function() {
            div.style.opacity = '0';
            div.style.transition = 'opacity 0.5s';
            setTimeout(function() { div.remove(); }, 500);
          }, 3000);
          window.history.replaceState({}, document.title, window.location.pathname);
        }
      });
    </script>
  </body>
</html>
