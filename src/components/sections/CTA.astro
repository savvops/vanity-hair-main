---
import Icon from '../ui/Icon.astro';
import Button from '../ui/Button.astro';
---

<section id="contact" class="py-20 md:py-24 bg-gradient-to-br from-primary to-accent">
  <div class="container">
    <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">
      <div class="grid lg:grid-cols-2">
        <!-- Left Content -->
        <div class="p-8 md:p-12 lg:p-16">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-dark mb-4">
            Ready for Crystal-Clear Windows?
          </h2>
          <p class="text-gray-600 mb-8">
            Get your free, no-obligation quote today. Join 1,500+ happy customers who trust Window Guys for their window cleaning needs.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <Button href="tel:+15551234567" variant="primary" size="lg" class="flex-1">
              <Icon name="phone" class="w-5 h-5" />
              Call (555) 123-4567
            </Button>
            <Button href="#contact" variant="outline" size="lg" class="flex-1" onclick="document.getElementById('quoteForm')?.scrollIntoView({behavior: 'smooth'}); return false;">
              <Icon name="mail" class="w-5 h-5" />
              Get Free Quote
            </Button>
          </div>
          
          <div class="flex flex-wrap gap-4 text-sm text-gray-600">
            <span class="flex items-center gap-2">
              <Icon name="check" class="w-4 h-4 text-success" />
              Free Estimates
            </span>
            <span class="flex items-center gap-2">
              <Icon name="check" class="w-4 h-4 text-success" />
              No Hidden Fees
            </span>
            <span class="flex items-center gap-2">
              <Icon name="check" class="w-4 h-4 text-success" />
              Same-Day Service Available
            </span>
          </div>
        </div>
        
        <!-- Right Form -->
        <div class="bg-gray-50 p-8 md:p-12 lg:p-16">
          <h3 class="font-display text-2xl font-bold text-dark mb-6">Get Your Free Quote</h3>
          
          <form id="quoteForm" class="space-y-4">
            <input type="text" name="name" placeholder="Your Name *" required 
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" />
            
            <input type="tel" name="phone" placeholder="Phone Number *" required 
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" />
            
            <input type="email" name="email" placeholder="Email Address" 
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" />
            
            <select name="property_type" required 
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all bg-white">
              <option value="">Type of Property *</option>
              <option value="residential">Residential Home</option>
              <option value="condo">Condo/Apartment</option>
              <option value="commercial">Commercial Building</option>
              <option value="other">Other</option>
            </select>
            
            <textarea name="message" placeholder="Tell us about your windows (number of windows, stories, etc.)" rows="3"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none"></textarea>
            
            <button type="submit" class="w-full bg-primary text-white font-display font-semibold py-4 rounded-xl hover:bg-primary-dark transition-colors flex items-center justify-center gap-2">
              <span class="btn-text flex items-center gap-2">
                <Icon name="mail" class="w-5 h-5" />
                Request Quote
              </span>
              <span class="btn-loading hidden items-center gap-2">
                <svg class="animate-spin h-5 w-5" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
                </svg>
                Sending...
              </span>
            </button>
            
            <p class="text-xs text-gray-500 text-center flex items-center justify-center gap-1">
              <Icon name="shield" class="w-3 h-3" />
              Your information is secure and will never be shared.
            </p>
          </form>
          
          <!-- Success Message -->
          <div id="formSuccess" class="hidden text-center py-8">
            <div class="w-16 h-16 bg-success/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <Icon name="check" class="w-8 h-8 text-success" />
            </div>
            <h4 class="font-display text-xl font-bold text-dark mb-2">Thank You!</h4>
            <p class="text-gray-600 mb-6">We've received your quote request. Our team will contact you within 24 hours.</p>
            <Button variant="outline" onclick="document.getElementById('quoteForm').style.display='block'; document.getElementById('formSuccess').classList.add('hidden'); document.getElementById('quoteForm').reset();">
              Send Another Request
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
