---
import siteData from '../../content/site.json';
const { navbar } = siteData;
---

<nav class="fixed w-full z-50 bg-rich-black/95 border-b border-gold/30 backdrop-blur-sm transition-all duration-300" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="#home" class="flex-shrink-0 flex items-center space-x-2 group">
        <i data-lucide="scissors" class="w-6 h-6 text-gold group-hover:rotate-12 transition-transform"></i>
        <span class="font-serif text-base md:text-lg font-bold tracking-wider text-white">
          {navbar.brand_name}
        </span>
      </a>

      <!-- Desktop Menu -->
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-8">
          {navbar.nav_links.map((link) => (
            <a 
              href={link.href} 
              class="text-gray-300 hover:text-gold transition-colors duration-300 text-sm uppercase tracking-widest"
            >
              {link.label}
            </a>
          ))}
          <a 
            href="#book" 
            class="bg-gold hover:bg-gold-light text-rich-black px-5 py-2 rounded-sm font-bold uppercase tracking-wider transition-all transform hover:scale-105"
          >
            {navbar.cta_button}
          </a>
        </div>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button id="mobile-menu-btn" class="text-gold hover:text-white focus:outline-none p-2">
          <i data-lucide="menu" class="w-6 h-6" id="menu-icon"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Panel -->
  <div id="mobile-menu" class="hidden md:hidden bg-charcoal border-b border-gold/20">
    <div class="px-4 pt-2 pb-4 space-y-1 text-center">
      {navbar.nav_links.map((link) => (
        <a 
          href={link.href} 
          class="block px-3 py-3 text-base font-medium text-gray-300 hover:text-gold transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a 
        href="#book" 
        class="block px-3 py-3 bg-gold text-rich-black font-bold mt-4 uppercase tracking-wider"
      >
        {navbar.cta_button}
      </a>
    </div>
  </div>
</nav>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  let isMenuOpen = false;

  mobileMenuBtn?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    mobileMenu?.classList.toggle('hidden');
    
    // Toggle icon between menu and X
    if (menuIcon) {
      if (isMenuOpen) {
        menuIcon.setAttribute('data-lucide', 'x');
      } else {
        menuIcon.setAttribute('data-lucide', 'menu');
      }
      window.lucide?.createIcons();
    }
  });

  // Close mobile menu when clicking a link
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      isMenuOpen = false;
      if (menuIcon) {
        menuIcon.setAttribute('data-lucide', 'menu');
        window.lucide?.createIcons();
      }
    });
  });

  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('shadow-lg', 'shadow-gold/5');
    } else {
      navbar?.classList.remove('shadow-lg', 'shadow-gold/5');
    }
  });
</script>
