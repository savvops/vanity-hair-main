---
const services = [
  {
    title: 'The Signature Cut',
    price: '$35',
    description: 'Includes consultation, precision cut, and style with premium products.',
  },
  {
    title: 'Hot Towel Shave',
    price: '$40',
    description: 'Straight razor shave with pre-shave oil, hot towels, and post-shave balm.',
  },
  {
    title: 'Beard Sculpt & Trim',
    price: '$25',
    description: 'Detailed shaping, trimming, and conditioning for your beard.',
  },
  {
    title: 'The Full Service',
    price: '$65',
    description: 'Haircut + Beard Trim + Hot Towel treatment. The ultimate relaxer.',
  },
  {
    title: 'Precision Fade',
    price: '$30',
    description: 'Skin fade, taper fade, or any variation. Clean, sharp edges guaranteed.',
  },
  {
    title: 'Father & Son',
    price: '$55',
    description: 'Classic cuts for both. A tradition worth keeping.',
  },
];
---

<section id="services" class="py-24 bg-charcoal relative">
  <div class="absolute top-0 w-full h-2 barber-pole opacity-30"></div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <i data-lucide="scissors" class="w-12 h-12 text-gold mx-auto mb-4"></i>
      <h2 class="text-4xl md:text-5xl font-serif font-bold text-white mb-4">Service Menu</h2>
      <div class="h-1 w-20 bg-gold mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
      {services.map((service) => (
        <div class="group relative bg-rich-black p-6 border border-gray-800 hover:border-gold transition-colors duration-300">
          <div class="flex justify-between items-baseline mb-2 relative z-10">
            <h3 class="text-xl font-bold text-white group-hover:text-gold transition-colors">{service.title}</h3>
            <span class="text-2xl font-serif text-gold">{service.price}</span>
          </div>
          <p class="text-gray-500 text-sm mb-2">{service.description}</p>
          <div class="border-b border-dashed border-gray-800 absolute bottom-6 left-6 right-6"></div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <p class="text-gray-400 italic mb-6">* Complimentary beverage with every service.</p>
      <a 
        href="#book" 
        class="inline-block px-8 py-3 border border-gold text-gold hover:bg-gold hover:text-rich-black transition-all duration-300 uppercase tracking-widest text-sm font-bold"
      >
        Book an Appointment
      </a>
    </div>
  </div>
</section>
