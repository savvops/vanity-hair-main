---
import Icon from '../ui/Icon.astro';

const steps = [
  {
    number: '01',
    icon: 'file-invoice',
    title: 'Request a Quote',
    description: 'Tell us about your property and we\'ll send a clear, no-pressure estimate.'
  },
  {
    number: '02',
    icon: 'calendar-check',
    title: 'Choose a Time',
    description: 'Pick a convenient date and time window that fits your schedule.'
  },
  {
    number: '03',
    icon: 'spray-can',
    title: 'We Clean',
    description: 'Our team arrives ready with pure water tanks and professional equipment.'
  },
  {
    number: '04',
    icon: 'smile',
    title: 'Inspect & Enjoy',
    description: 'We walk through the result with you so you can enjoy crystal-clear windows.'
  },
];
---

<section id="process" class="py-20 md:py-24 bg-white">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">Simple Process</span>
      <h2 class="section-title">From Quote to Shine in 4 Easy Steps</h2>
    </div>
    
    <div class="flex flex-wrap justify-center items-start gap-4">
      {steps.map((step, index) => (
        <>
          <div 
            class="reveal opacity-0 translate-y-8 flex-1 min-w-[220px] max-w-[280px] text-center relative"
            style={`transition-delay: ${index * 150}ms`}
          >
            <span class="font-display text-7xl md:text-8xl font-extrabold text-primary-light absolute top-0 left-1/2 -translate-x-1/2 -z-10 leading-none">
              {step.number}
            </span>
            <div class="relative z-10 bg-white p-8 rounded-2xl shadow-lg border border-gray-100 mt-8">
              <div class="w-16 h-16 bg-primary-light rounded-full flex items-center justify-center mx-auto mb-5">
                <Icon name={step.icon} class="w-7 h-7 text-primary" />
              </div>
              <h3 class="font-display text-lg font-semibold text-dark mb-2">{step.title}</h3>
              <p class="text-gray-600 text-sm">{step.description}</p>
            </div>
          </div>
          
          {index < steps.length - 1 && (
            <div class="hidden lg:block w-16 h-0.5 bg-primary-light mt-24"></div>
          )}
        </>
      ))}
    </div>
  </div>
</section>
