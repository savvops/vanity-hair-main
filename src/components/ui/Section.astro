---
interface Props {
  id?: string;
  class?: string;
  background?: 'white' | 'gray' | 'gradient';
  padding?: 'sm' | 'md' | 'lg';
}

const { 
  id, 
  class: className = '',
  background = 'white',
  padding = 'lg'
} = Astro.props;

const backgrounds = {
  white: 'bg-white',
  gray: 'bg-gray-50',
  gradient: 'bg-gradient-to-br from-primary to-accent',
};

const paddings = {
  sm: 'py-12',
  md: 'py-16',
  lg: 'py-20 md:py-24',
};

const classes = `${backgrounds[background]} ${paddings[padding]} ${className}`;
---

<section id={id} class={classes}>
  <div class="container">
    <slot />
  </div>
</section>
