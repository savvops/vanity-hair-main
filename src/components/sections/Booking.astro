---
import siteData from '../../content/site.json';
const { booking } = siteData;
const { fields, contact_info } = booking;
---

<section id="book" class="py-24 bg-rich-black">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Booking Form -->
      <div id="contact" class="bg-charcoal p-8 md:p-12 border-t-4 border-gold">
        <h3 class="text-3xl font-serif font-bold text-white mb-2">{booking.form_title}</h3>
        <p class="text-gray-400 mb-8">{booking.form_subtitle}</p>

        <form class="space-y-6" action={`https://formspree.io/f/${booking.formspree_id}`} method="POST">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-gray-400 text-sm uppercase tracking-wider mb-2">{fields.name_label}</label>
              <input 
                type="text" 
                name="name"
                required
                class="w-full bg-rich-black border border-gray-700 text-white p-3 focus:border-gold focus:outline-none transition-colors calendar-dark"
                placeholder={fields.name_placeholder}
              />
            </div>
            <div>
              <label class="block text-gray-400 text-sm uppercase tracking-wider mb-2">{fields.phone_label}</label>
              <input 
                type="tel" 
                name="phone"
                required
                class="w-full bg-rich-black border border-gray-700 text-white p-3 focus:border-gold focus:outline-none transition-colors calendar-dark"
                placeholder={fields.phone_placeholder}
              />
            </div>
          </div>
          <div>
            <label class="block text-gray-400 text-sm uppercase tracking-wider mb-2">{fields.service_label}</label>
            <select 
              name="service"
              class="w-full bg-rich-black border border-gray-700 text-white p-3 focus:border-gold focus:outline-none transition-colors"
            >
              {fields.service_options.map((option) => (
                <option>{option}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-gray-400 text-sm uppercase tracking-wider mb-2">{fields.date_label}</label>
            <input 
              type="date" 
              name="date"
              class="w-full bg-rich-black border border-gray-700 text-white p-3 focus:border-gold focus:outline-none transition-colors calendar-dark"
            />
          </div>
          <div>
            <label class="block text-gray-400 text-sm uppercase tracking-wider mb-2">{fields.time_label}</label>
            <select 
              name="time"
              class="w-full bg-rich-black border border-gray-700 text-white p-3 focus:border-gold focus:outline-none transition-colors"
            >
              {fields.time_options.map((time) => (
                <option>{time}</option>
              ))}
            </select>
          </div>
          <button 
            type="submit" 
            class="w-full bg-gold text-rich-black font-bold py-4 uppercase tracking-widest hover:bg-white transition-colors duration-300"
          >
            {fields.submit_button}
          </button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="flex flex-col justify-center space-y-8">
        <div>
          <h3 class="text-gold uppercase tracking-widest font-bold mb-4">{contact_info.find_us_title}</h3>
          <p class="text-2xl text-white font-serif mb-2">{contact_info.business_name}</p>
          <p class="text-gray-400">
            {contact_info.address_line1}<br />
            {contact_info.address_line2}
          </p>
          <a 
            href={contact_info.directions_link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center space-x-2 text-gold hover:text-white transition-colors mt-4"
          >
            <i data-lucide="map-pin" class="w-4 h-4"></i>
            <span>{contact_info.directions_label}</span>
          </a>
        </div>

        <div>
          <h3 class="text-gold uppercase tracking-widest font-bold mb-4">{contact_info.hours_title}</h3>
          <div class="grid grid-cols-2 gap-4 text-gray-400 max-w-sm">
            {contact_info.hours.map((item) => (
              <>
                <span>{item.day}</span> 
                <span class={item.highlight ? "text-gold" : ""}>{item.hours}</span>
              </>
            ))}
          </div>
          <p class="text-gray-500 text-sm mt-3 italic">{contact_info.hours_note}</p>
        </div>

        <div>
          <h3 class="text-gold uppercase tracking-widest font-bold mb-4">{contact_info.contact_title}</h3>
          <a 
            href={contact_info.phone_href}
            class="text-gray-400 text-lg hover:text-gold transition-colors cursor-pointer flex items-center space-x-3"
          >
            <i data-lucide="phone" class="w-5 h-5"></i>
            <span>{contact_info.phone}</span>
          </a>
          <a 
            href={contact_info.instagram_link}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 text-lg hover:text-gold transition-colors cursor-pointer flex items-center space-x-3 mt-4"
          >
            <i data-lucide="instagram" class="w-5 h-5"></i>
            <span>{contact_info.instagram_handle}</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
