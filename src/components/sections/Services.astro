---
import { getCollection } from 'astro:content';
import Icon from '../ui/Icon.astro';

const services = await getCollection('services');
const sortedServices = services.sort((a, b) => a.data.order - b.data.order);
---

<section id="services" class="py-20 md:py-24 bg-white">
  <div class="container">
    <div class="section-header">
      <span class="section-badge">Our Services</span>
      <h2 class="section-title">Everything You Need for a Cleaner Exterior</h2>
      <p class="section-subtitle">From residential homes to commercial buildings, we've got you covered</p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sortedServices.map((service, index) => (
        <div 
          class={`reveal opacity-0 translate-y-8 p-8 rounded-2xl border transition-all duration-300 hover:-translate-y-2 hover:shadow-xl ${
            service.data.featured 
              ? 'bg-gradient-to-br from-primary to-accent text-white border-transparent' 
              : 'bg-white border-gray-200 hover:border-primary-light'
          }`}
          style={`transition-delay: ${index * 100}ms`}
        >
          <div class={`w-16 h-16 rounded-xl flex items-center justify-center mb-6 ${
            service.data.featured 
              ? 'bg-white/20 text-white' 
              : 'bg-primary-light text-primary'
          }`}>
            <Icon name={service.data.icon} class="w-8 h-8" />
          </div>
          
          <h3 class={`font-display text-xl font-semibold mb-3 ${
            service.data.featured ? 'text-white' : 'text-dark'
          }`}>
            {service.data.title}
          </h3>
          
          <p class={`mb-6 ${service.data.featured ? 'text-white/90' : 'text-gray-600'}`}>
            {service.data.description}
          </p>
          
          <ul class="space-y-2">
            {service.data.features.map(feature => (
              <li class={`flex items-center gap-3 text-sm ${
                service.data.featured ? 'text-white' : 'text-gray-700'
              }`}>
                <Icon name="check" class={`w-4 h-4 ${
                  service.data.featured ? 'text-white' : 'text-success'
                }`} />
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
