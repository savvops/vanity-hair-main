---
const currentYear = new Date().getFullYear();
---

<footer class="bg-black py-12 border-t border-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center">
      <!-- Logo -->
      <div class="mb-6 md:mb-0 text-center md:text-left">
        <span class="font-serif text-lg font-bold tracking-wider text-white">
          VANITY <span class="text-gold">HAIR</span> & ESTHETICS
        </span>
        <p class="text-gray-600 text-sm mt-2">
          432 Graham Ave, Winnipeg, MB R3C 0L8<br />
          © {currentYear} Vanity Hair & Esthetics. All rights reserved.
        </p>
      </div>

      <!-- Social Links -->
      <div class="flex space-x-6">
        <a 
          href="https://www.facebook.com/vanityhairwpg/" 
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-500 hover:text-gold transition-colors"
          aria-label="Facebook"
        >
          <i data-lucide="facebook" class="w-6 h-6"></i>
        </a>
        <a 
          href="https://www.instagram.com/vanity.hair.204/" 
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-500 hover:text-gold transition-colors"
          aria-label="Instagram"
        >
          <i data-lucide="instagram" class="w-6 h-6"></i>
        </a>
      </div>
    </div>
    
    <!-- Quick Links -->
    <div class="mt-8 pt-8 border-t border-gray-900">
      <div class="flex flex-wrap justify-center gap-6 text-sm">
        <a href="#home" class="text-gray-500 hover:text-gold transition-colors">Home</a>
        <a href="#about" class="text-gray-500 hover:text-gold transition-colors">About</a>
        <a href="#services" class="text-gray-500 hover:text-gold transition-colors">Services</a>
        <a href="#gallery" class="text-gray-500 hover:text-gold transition-colors">Gallery</a>
        <a href="#book" class="text-gray-500 hover:text-gold transition-colors">Book Now</a>
      </div>
    </div>
  </div>
</footer>
