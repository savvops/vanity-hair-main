---
import { getEntry } from 'astro:content';
const bookingData = await getEntry('booking', 'settings');
const contactInfo = await getEntry('contactInfo', 'info');

const booking = bookingData?.data || {
  formTitle: 'Book Your Visit',
  formSubtitle: 'Walk-ins welcome, but appointments are prioritized.',
  formspreeId: 'YOUR_FORM_ID',
  nameLabel: 'Name',
  namePlaceholder: 'Your name',
  phoneLabel: 'Phone',
  phonePlaceholder: '(204) 956-5797',
  serviceLabel: 'Service',
  serviceOptions: [],
  dateLabel: 'Preferred Date',
  timeLabel: 'Preferred Time',
  timeOptions: [],
  submitButton: 'Confirm Booking'
};

const contact = contactInfo?.data || {
  findUsTitle: 'Find Us',
  businessName: 'Vanity Hair & Esthetics',
  addressLine1: '432 Graham Avenue',
  addressLine2: 'Winnipeg, MB R3C 0L8',
  directionsLink: '#',
  directionsLabel: 'Get Directions',
  hoursTitle: 'Opening Hours',
  hours: [],
  hoursNote: '',
  contactTitle: 'Contact',
  phone: '(204) 956-5797',
  phoneHref: 'tel:2049565797',
  instagramHandle: '@vanity.hair.204',
  instagramLink: 'https://www.instagram.com/vanity.hair.204/'
};
---

<section id="book" class="py-24 bg-rich-black scroll-mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Booking Form -->
      <div id="contact" class="bg-charcoal p-8 md:p-12 border-t-4 border-gold">
        <h3 class="text-3xl font-serif font-bold text-white mb-2">{booking.formTitle}</h3>
        <p class="text-gray-400 mb-8">{booking.formSubtitle}</p>

        <form class="space-y-6" action={`https://formspree.io/f/${booking.formspreeId}`} method="POST">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-gray-400 text-sm uppercase tracking-wider mb-2">{booking.nameLabel}</label>
              <input 
                type="text" 
                name="name"
                required
                class="w-full bg-rich-black border border-gray-700 text-white p-3 focus:border-gold focus:outline-none transition-colors calendar-dark"
                placeholder={booking.namePlaceholder}
              />
            </div>
            <div>
              <label class="block text-gray-400 text-sm uppercase tracking-wider mb-2">{booking.phoneLabel}</label>
              <input 
                type="tel" 
                name="phone"
                required
                class="w-full bg-rich-black border border-gray-700 text-white p-3 focus:border-gold focus:outline-none transition-colors calendar-dark"
                placeholder={booking.phonePlaceholder}
              />
            </div>
          </div>
          <div>
            <label class="block text-gray-400 text-sm uppercase tracking-wider mb-2">{booking.serviceLabel}</label>
            <select 
              name="service"
              class="w-full bg-rich-black border border-gray-700 text-white p-3 focus:border-gold focus:outline-none transition-colors"
            >
              {booking.serviceOptions?.map((opt: any) => (
                <option>{opt.option}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-gray-400 text-sm uppercase tracking-wider mb-2">{booking.dateLabel}</label>
            <input 
              type="date" 
              name="date"
              class="w-full bg-rich-black border border-gray-700 text-white p-3 focus:border-gold focus:outline-none transition-colors calendar-dark"
            />
          </div>
          <div>
            <label class="block text-gray-400 text-sm uppercase tracking-wider mb-2">{booking.timeLabel}</label>
            <select 
              name="time"
              class="w-full bg-rich-black border border-gray-700 text-white p-3 focus:border-gold focus:outline-none transition-colors"
            >
              {booking.timeOptions?.map((opt: any) => (
                <option>{opt.time}</option>
              ))}
            </select>
          </div>
          <button 
            type="submit" 
            class="w-full bg-gold text-rich-black font-bold py-4 uppercase tracking-widest hover:bg-white transition-colors duration-300"
          >
            {booking.submitButton}
          </button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="flex flex-col justify-center space-y-8">
        <div>
          <h3 class="text-gold uppercase tracking-widest font-bold mb-4">{contact.findUsTitle}</h3>
          <p class="text-2xl text-white font-serif mb-2">{contact.businessName}</p>
          <p class="text-gray-400">
            {contact.addressLine1}<br />
            {contact.addressLine2}
          </p>
          <a 
            href={contact.directionsLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center space-x-2 text-gold hover:text-white transition-colors mt-4"
          >
            <i data-lucide="map-pin" class="w-4 h-4"></i>
            <span>{contact.directionsLabel}</span>
          </a>
        </div>

        <div>
          <h3 class="text-gold uppercase tracking-widest font-bold mb-4">{contact.hoursTitle}</h3>
          <div class="grid grid-cols-2 gap-4 text-gray-400 max-w-sm">
            {contact.hours?.map((item: any) => (
              <>
                <span>{item.day}</span> 
                <span class={item.highlight ? "text-gold" : ""}>{item.hours}</span>
              </>
            ))}
          </div>
          <p class="text-gray-500 text-sm mt-3 italic">{contact.hoursNote}</p>
        </div>

        <div>
          <h3 class="text-gold uppercase tracking-widest font-bold mb-4">{contact.contactTitle}</h3>
          <a 
            href={contact.phoneHref}
            class="text-gray-400 text-lg hover:text-gold transition-colors cursor-pointer flex items-center space-x-3"
          >
            <i data-lucide="phone" class="w-5 h-5"></i>
            <span>{contact.phone}</span>
          </a>
          <a 
            href={contact.instagramLink}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 text-lg hover:text-gold transition-colors cursor-pointer flex items-center space-x-3 mt-4"
          >
            <i data-lucide="instagram" class="w-5 h-5"></i>
            <span>{contact.instagramHandle}</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
