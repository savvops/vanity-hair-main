---
import Icon from '../ui/Icon.astro';

const features = [
  {
    icon: 'shield',
    title: 'Safer Technology',
    description: 'Our purified water-fed poles reduce ladder use and create a safer cleaning process for everyone.'
  },
  {
    icon: 'heart',
    title: 'Extraordinary Service',
    description: 'We communicate clearly, arrive prepared, and treat your home or business like it\'s our own.'
  },
  {
    icon: 'medal',
    title: 'Guaranteed Results',
    description: 'If you\'re not completely satisfied, we\'ll make it right. Your confidence matters to us.'
  },
  {
    icon: 'leaf',
    title: 'Eco-Friendly',
    description: 'No harsh chemicals. Just pure water that dries spot-free and is safe for your family and plants.'
  },
];
---

<section id="why-us" class="py-20 md:py-24 bg-gray-50">
  <div class="container">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Content -->
      <div>
        <span class="section-badge">Why Choose Window Guys</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-dark mb-6">
          Big-Company Reliability,<br />Local-Team Care
        </h2>
        <p class="text-lg text-gray-600 mb-10">
          We use advanced filtration systems and extendable poles to clean windows from the ground level. Purified water dries spot-free without harsh chemicals.
        </p>
        
        <div class="space-y-6">
          {features.map((feature, index) => (
            <div 
              class="reveal opacity-0 translate-y-8 flex gap-5"
              style={`transition-delay: ${index * 100}ms`}
            >
              <div class="w-14 h-14 bg-white rounded-xl flex items-center justify-center shadow-md flex-shrink-0">
                <Icon name={feature.icon} class="w-6 h-6 text-primary" />
              </div>
              <div>
                <h4 class="font-display text-lg font-semibold text-dark mb-1">{feature.title}</h4>
                <p class="text-gray-600">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <!-- Image -->
      <div class="relative reveal opacity-0 translate-y-8">
        <img 
          src="https://images.unsplash.com/photo-1628177142898-93e36e4e3a50?w=600&h=700&fit=crop" 
          alt="Window cleaner using water-fed pole system reaching high windows safely"
          class="w-full rounded-3xl shadow-2xl"
        />
        <div class="absolute -bottom-6 -right-6 bg-primary text-white px-8 py-6 rounded-2xl shadow-xl">
          <span class="block font-display text-5xl font-extrabold">10+</span>
          <span class="text-sm font-medium opacity-90">Years of<br/>Excellence</span>
        </div>
      </div>
    </div>
  </div>
</section>
