---
---

<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/images/vanity hair exterior.webp" 
      alt="Vanity Hair & Esthetics Exterior"
      class="w-full h-full object-cover"
    />
    <!-- Lighter overlay for better image visibility -->
    <div class="absolute inset-0 bg-rich-black/40"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-rich-black/80 via-rich-black/20 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto mt-20">
    <div class="inline-block mb-4 animate-fade-in">
      <div class="h-1 w-24 bg-gold mx-auto mb-6"></div>
      <p class="text-gold uppercase tracking-[0.3em] text-sm md:text-base font-bold mb-2">💈 Est. 2016 💈</p>
    </div>
    
    <h1 class="text-5xl md:text-7xl lg:text-8xl font-serif font-bold text-white mb-6 text-shadow leading-tight animate-slide-up">
      Sharp Cuts.<br />
      <span class="text-gold italic">Timeless Style.</span>
    </h1>
    
    <p class="text-gray-100 text-lg md:text-xl max-w-2xl mx-auto mb-10 font-light animate-fade-in drop-shadow-lg">
      Vanity Hair & Esthetics - Winnipeg's premier destination for precision fades, classic cuts, and hot towel shaves. Where craftsmanship meets confidence.
    </p>
    
    <div class="flex flex-col sm:flex-row justify-center gap-4 animate-slide-up">
      <a 
        href="#book" 
        class="px-8 py-4 bg-gold text-rich-black font-bold text-lg uppercase tracking-wider hover:bg-gold-light transition-colors rounded-sm shadow-[0_0_20px_rgba(212,175,55,0.5)]"
      >
        Book Appointment
      </a>
      <a 
        href="#services" 
        class="px-8 py-4 border-2 border-gold text-gold font-bold text-lg uppercase tracking-wider hover:bg-gold hover:text-rich-black transition-colors rounded-sm backdrop-blur-sm bg-black/20"
      >
        View Services
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-10 animate-bounce">
    <a href="#info" class="text-gold hover:text-white transition-colors drop-shadow-lg">
      <i data-lucide="chevron-down" class="w-8 h-8"></i>
    </a>
  </div>
</section>
