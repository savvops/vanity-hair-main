---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Vanity Hair & Esthetics | Premium Barbershop Winnipeg",
  description = "Vanity Hair & Esthetics - Premium barbershop in Winnipeg. Sharp cuts, fades, beard trims & hot towel shaves. Located at 432 Graham Ave. Call (204) 956-5797"
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "HairSalon",
  "name": "Vanity Hair & Esthetics",
  "image": "https://vanityhair.pages.dev/images/2026-01-23_21-27-27_UTC.jpg",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "432 Graham Ave",
    "addressLocality": "Winnipeg",
    "addressRegion": "MB",
    "postalCode": "R3C 0L8",
    "addressCountry": "CA"
  },
  "telephone": "+12049565797",
  "priceRange": "$$",
  "openingHours": [
    "Mo 09:00-20:30",
    "Tu 09:00-20:30",
    "We 09:00-20:30",
    "Th 09:00-20:30",
    "Fr 09:00-20:30",
    "Sa 09:00-20:30"
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="business.business" />
    <meta property="og:url" content="https://vanityhair.pages.dev" />
    <meta property="og:image" content="https://vanityhair.pages.dev/images/2026-01-23_21-27-27_UTC.jpg" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://vanityhair.pages.dev/images/2026-01-23_21-27-27_UTC.jpg" />
    
    <!-- Canonical -->
    <link rel="canonical" href="https://vanityhair.pages.dev" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    
    <title>{title}</title>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
  </head>
  <body class="bg-rich-black text-white">
    <slot />
    <script>
      // Initialize Lucide icons
      document.addEventListener('DOMContentLoaded', () => {
        if (window.lucide) {
          window.lucide.createIcons();
        }
      });
    </script>
  </body>
</html>
