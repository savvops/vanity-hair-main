---
import { getCollection, getEntry } from 'astro:content';
const settings = await getEntry('testimonialsSettings', 'settings');
const testimonials = await getCollection('testimonials');
const sortedTestimonials = testimonials?.sort((a: any, b: any) => (a.data.order || 0) - (b.data.order || 0)) || [];
const { heading, ratingScore, ratingLabel, reviewsButton, reviewsButtonLink, backgroundImage } = settings?.data || {
  heading: 'What Our Clients Say',
  ratingScore: '4.7',
  ratingLabel: 'Based on 53 Google Reviews',
  reviewsButton: 'Read All Google Reviews',
  reviewsButtonLink: '#',
  backgroundImage: '/images/2025-12-18_03-11-39_UTC.jpg'
};
---

<section id="testimonials" class="py-24 relative bg-fixed bg-cover bg-center min-h-[50vh] flex items-center">
  <div class="absolute inset-0 bg-rich-black/80 z-10"></div>
  <div class="absolute inset-0 z-0">
    <img 
      src={backgroundImage} 
      alt="Barbershop background"
      class="w-full h-full object-cover"
    />
  </div>
  
  <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Google Reviews Summary Card -->
    <div class="bg-charcoal/90 backdrop-blur-sm p-8 border border-gold/30 rounded-lg mb-12 text-center max-w-2xl mx-auto">
      <div class="flex items-center justify-center space-x-2 mb-2">
        <i data-lucide="star" class="w-8 h-8 text-gold fill-current"></i>
        <span class="text-4xl font-bold text-white">{ratingScore}</span>
      </div>
      <div class="flex items-center justify-center space-x-1 mb-2">
        {Array.from({ length: 5 }).map(() => (
          <i data-lucide="star" class="w-5 h-5 text-gold fill-current"></i>
        ))}
      </div>
      <p class="text-gray-400 mb-4">{ratingLabel}</p>
      <a 
        href={reviewsButtonLink}
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center space-x-2 px-6 py-3 bg-gold text-rich-black font-bold uppercase tracking-wider hover:bg-white transition-colors"
      >
        <i data-lucide="message-square" class="w-5 h-5"></i>
        <span>{reviewsButton}</span>
      </a>
    </div>

    <!-- Individual Reviews -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {sortedTestimonials.map((testimonial: any) => (
        <div class="bg-charcoal/80 backdrop-blur-sm p-6 border border-gold/20">
          <div class="flex items-center space-x-1 text-gold mb-3">
            {Array.from({ length: testimonial.data.rating }).map(() => (
              <i data-lucide="star" class="w-4 h-4 fill-current"></i>
            ))}
          </div>
          <p class="text-gray-300 text-sm leading-relaxed mb-4 line-clamp-6">
            "{testimonial.data.text}"
          </p>
          <div class="border-t border-gray-700 pt-3">
            <p class="text-white font-semibold text-sm">{testimonial.data.author}</p>
            <p class="text-gray-500 text-xs">{testimonial.data.time}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
